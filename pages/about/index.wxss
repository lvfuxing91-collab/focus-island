.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 144rpx;
  height: 144rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1E2A2F;
  margin-bottom: 8rpx;
}

.version {
  font-size: 24rpx;
  color: #95A5A6;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0F6C8C;
  margin-bottom: 24rpx;
}

.content {
  font-size: 26rpx;
  color: #4A5A60;
  line-height: 1.6;
  margin-bottom: 16rpx;
  text-align: justify;
}

.content:last-child {
  margin-bottom: 0;
}