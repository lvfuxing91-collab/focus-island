.history-container {
  padding: 0;
  background-color: #EBF4F6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.filter-tabs {
  background-color: #EBF4F6;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.custom-nav {
  background-color: transparent !important;
}

.history-list-scroll {
  flex: 1;
  padding: 0 32rpx 60rpx;
  box-sizing: border-box;
}

.date-group {
  margin-bottom: 40rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
}

.date-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1E2A2F;
}

.day-total {
  font-size: 24rpx;
  color: #6C8A9B;
}

.session-list {
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(15, 108, 140, 0.05);
}

.session-collapse-item {
  margin-bottom: 2rpx;
}

.session-header {
  display: flex;
  align-items: center;
  width: 100%;
}

.tag-indicator {
  width: 12rpx;
  height: 60rpx;
  border-radius: 6rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.session-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.session-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 4rpx;
}

.session-duration {
  font-size: 32rpx;
  font-weight: bold;
  color: #0F6C8C;
  margin-right: 12rpx;
}

.session-count {
  font-size: 24rpx;
  color: #95A5A6;
}

.session-time {
  font-size: 24rpx;
  color: #6B7C85;
}

.session-collapse-content {
  padding: 0 !important;
  background-color: #F9FCFD !important;
}

.item-details {
  padding: 20rpx 32rpx 30rpx 80rpx;
}

.task-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  background: #fff;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.task-row:last-child {
  margin-bottom: 24rpx;
}

.task-actions {
  padding: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-task-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0F6C8C;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 16rpx;
  background: rgba(15, 108, 140, 0.05);
  margin-top: 10rpx;
}

.task-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 28rpx;
  color: #1E2A2F;
  display: block;
  margin-bottom: 4rpx;
}

.task-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-tag {
  font-size: 22rpx;
  color: #6B7C85;
  background-color: #F0F4F8;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.task-time {
  font-size: 22rpx;
  color: #95A5A6;
}

.empty-state {
  padding-top: 200rpx;
}

.start-btn {
  width: 320rpx !important;
  margin-top: 40rpx !important;
}

.time-picker-popup {
  padding: 40rpx 32rpx 60rpx;
  background: #fff;
}

.popup-header {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #1E2A2F;
}

.picker-group {
  background: #F6FAFC;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 30rpx;
}

.picker-row {
  height: 100rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #E7EFF3;
}

.picker-row:last-child {
  border-bottom: none;
}

.picker-row .label {
  font-size: 28rpx;
  color: #6B7C85;
}

.picker-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #0F6C8C;
}

.popup-tips {
  font-size: 24rpx;
  color: #95A5A6;
  text-align: center;
  margin-bottom: 40rpx;
}

.save-btn {
  height: 88rpx !important;
  border-radius: 44rpx !important;
}
