.floating-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 88rpx;
  background-color: #0F6C8C;
  z-index: 9999;
  transform: translateY(-100%);
  transition: transform 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(15, 108, 140, 0.2);
}

.floating-bar.show {
  transform: translateY(0);
}

.bar-content {
  height: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
}

.timer-info {
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 28rpx;
}

.emoji {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.status-text {
  font-weight: 500;
  margin-right: 16rpx;
}

.time-text {
  font-family: monospace;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 24rpx;
}

.back-btn text {
  margin-right: 4rpx;
}